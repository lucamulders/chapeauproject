@model IEnumerable<ChapeauProject.ViewModels.TablesViewModel>

@{
    ViewData["Title"] = "Tables";
    int free = Model.Count(t => !t.Table.IsOccupied);
    int occupied = Model.Count(t => t.Table.IsOccupied);
}

<div style="display:flex; gap:12px; margin-bottom:1.5rem;">
    <div class="stat-card"><div class="stat-label">Total</div><div class="stat-value">@Model.Count()</div></div>
    <div class="stat-card"><div class="stat-label">Free</div><div class="stat-value" style="color:#3B6D11">@free</div></div>
    <div class="stat-card"><div class="stat-label">Occupied</div><div class="stat-value" style="color:#A32D2D">@occupied</div></div>
</div>

<div class="tables-grid">
    @foreach (var item in Model.OrderBy(t => t.Table.TableNumber))
    {
        <div class="table-card">
            <form asp-action="ToggleOccupied" asp-controller="Tables" method="post" style="width:100%; display:flex; flex-direction:column; align-items:center; gap:8px;">
                <input type="hidden" name="tableNumber" value="@item.Table.TableNumber" />
                <button type="submit" class="table-toggle-btn">
                    <div class="table-shape @(item.Table.Seats <= 2 ? "round" : item.Table.Seats <= 4 ? "rect" : "large") @(item.Table.IsOccupied ? "occupied" : "free")">
                        <i class="ti ti-armchair"></i>
                    </div>
                </button>
                <div class="table-num">Table @item.Table.TableNumber</div>
                <div class="table-seats">@item.Table.Seats seats</div>
                <span class="status-badge @(item.Table.IsOccupied ? "badge-occupied" : "badge-free")">
                    @(item.Table.IsOccupied ? "Occupied" : "Free")
                </span>
                <span class="table-seats">@item.OrderCount orders</span>
            </form>
            <a asp-action="Details" asp-controller="Tables"
                   asp-route-id="@item.Table.TableNumber" class="view-orders-btn">
                View Orders
            </a>
        </div>
    }
</div>